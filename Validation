int choice;

cout << "1. Add Appliance\n";
cout << "2. Calculate Energy\n";
cout << "3. Exit\n";
cout << "Enter your choice: ";
cin >> choice;

// Validate input
while (cin.fail() || choice < 1 || choice > 3)
